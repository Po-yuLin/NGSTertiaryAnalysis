 * results for any clinical or research purpose. Users are
 * solely responsible for validating and interpreting all
 * results. This software shall not be held liable for any
 * direct, indirect, or consequential damages arising from
 * its use.
 * =========================================================
 * nextflow_tertiary.config
 * ========================
 * 三級分析 Nextflow 設定檔
 *
 * 路徑設計原則（與二級 config 相同模式）：
 *   - profiles 設定各環境的根目錄（ref_dir、sif_dir 等）
 *   - profiles 之後的 params {} 從根目錄推導其他路徑
 *   - 推導用的 params {} 裡不能再宣告 ref_dir = null，
 *     否則會把 profile 設好的值蓋回 null
 *
 * LOFTEE gerp workaround：
 *   LOFTEE 的 gerp_dist.pl 有 bug，將 loftee_path 直接與檔名拼接（無 /），
 *   解決方式是透過 --bind 把 gerp bw 直接掛載至 /opt/vep/Plugins/gerp_...bw
 *   此 bind 在 VEP_ANNOTATE process 的 containerOptions 裡設定
 */

apptainer {
    enabled    = true
    autoMounts = true
}

// ── Step 1：各環境只需設定根目錄 ─────────────────────────────

profiles {

    local {
        params {
            ref_dir     = "/scratch/pylin1991/GenomicReference_Cache/hg38"
            sif_dir     = "/data/pylin1991/nf-containers"
            scripts_dir = "/data/pylin1991/nf-containers/NGStertiary/1_0_0/scripts"
            out_dir     = "/scratch/pylin1991/tertiary_test"

            apptainer_base_opts = "--bind /scratch,/data"
            use_gpu_pangolin    = true
            use_gpu_evo2        = true
        }

        apptainer {
            runOptions = "--bind /scratch,/data"
        }

        process {
            withLabel: process_low    { cpus = 2;  memory = 8.GB  }
            withLabel: process_medium { cpus = 8;  memory = 32.GB }
            withLabel: process_high   { cpus = 16; memory = 64.GB }
            withLabel: process_gpu {
                containerOptions = "--nv"
                maxForks = 1
            }
        }
    }

    dgm {
        params {
            ref_dir     = "/home/pipeline/reference/hg38"
            sif_dir     = "/home/pipeline/nextflow_containers"
            scripts_dir = "/home/pipeline/tertiary_code/scripts"
            out_dir     = "/home/pipeline/tertiary_output"

            apptainer_base_opts = "--bind /home"
            use_gpu_pangolin    = true
            use_gpu_evo2        = false
        }

        apptainer {
            runOptions = "--bind /home"
        }

        process {
            withLabel: process_low    { cpus = 2;  memory = 8.GB  }
            withLabel: process_medium { cpus = 8;  memory = 32.GB }
            withLabel: process_high   { cpus = 32; memory = 64.GB }
            withLabel: process_gpu {
                containerOptions = "--nv"
                maxForks = 1
            }
        }
    }
}

// ── Step 2：從根目錄推導所有路徑 ─────────────────────────────
// 注意：這裡不宣告 ref_dir / sif_dir / scripts_dir，
//       否則會把 profile 設好的值蓋回 null

params {
    // ── 必填（執行時傳入）──────────────────────────────────────
    // Sample sheet CSV 欄位：sample_id, pipeline_type, input_dir, seq_type, hpo
    //   pipeline_type（在 sample sheet 裡）：nckuh 或 dragen
    //   nckuh 路徑規則：{input_dir}/04_snv_indel/{sample_id}.ensemble.fixed.vcf.gz
    //   dragen 路徑規則：{input_dir}/vcf.gz/{sample_id}.hard-filtered.vcf.gz
    samplesheet = null
    out_dir     = null

    // ── 選填：pipeline_type 過濾器 ────────────────────────────
    // 不傳入（null）→ sample sheet 內所有 row 的 pipeline_type 必須一致
    // 傳入值       → 只跑符合的 row，其他 row warn 後跳過
    //               例如：--pipeline_type dragen
    pipeline_type = null

    // ── 分析選項（全域設定，影響所有樣本）────────────────────
    run_evo2    = false
    run_phasing = false

    // parse_vep_csq.py 的輸入類型（由 sample sheet 的 pipeline_type 自動推導）
    // 通常不需要手動設定
    input_type  = null

    // 共用 Reference（從 ref_dir 推導）
    ref_fasta    = "${params.ref_dir}/Homo_sapiens_assembly38.fasta"

    // 三級分析專用資料庫（從 ref_dir/tertiary 推導）
    tertiary_dir = "${params.ref_dir}/tertiary"
    vep_cache    = "${params.ref_dir}/tertiary/vep_cache"
    dbnsfp       = "${params.ref_dir}/tertiary/dbnsfp/dbNSFP4.9c_with_pknn_grch38.gz"
    loftee_dir   = "${params.ref_dir}/tertiary/loftee"
    clinvar      = "${params.ref_dir}/tertiary/clinvar/clinvar_20260510.vcf.gz"
    clinvar_lookup_tsv = "${params.ref_dir}/tertiary/clinvar/clinvar_lookup.tsv.gz"
    gnomad_dir   = "${params.ref_dir}/tertiary/gnomad"
    pangolin_db  = "${params.ref_dir}/tertiary/pangolin/gencode.v47.annotation.db"
    strchive         = "${params.ref_dir}/tertiary/strchive/STRchive-loci.json"
    str_lookup_varid = "${params.ref_dir}/tertiary/strchive/str_lookup_varid.tsv.gz"
    str_lookup_pos   = "${params.ref_dir}/tertiary/strchive/str_lookup_pos.tsv.gz"
    mitomap_dir         = "${params.ref_dir}/tertiary/mitomap"
    // gnomAD mito v3.1 lookup（CC0，取代 MITOMAP CC BY-NC）
    gnomad_mito_lookup  = "${params.ref_dir}/tertiary/gnomad_mito/gnomad_mito_lookup.tsv.gz"

    // AnnotSV annotation databases（annotationsDir 要指向 share/AnnotSV/）
    annotsv_annotations = "${params.ref_dir}/tertiary/annotsv_annotations/share/AnnotSV"

    // ClinGen 資料庫（PVS1 HI 過濾 + PM2 MOI 判斷）
    // 下載：
    //   cd ${ref_dir}/tertiary/clingen
    //   wget https://ftp.clinicalgenome.org/ClinGen_gene_curation_list_GRCh38.tsv
    //   wget "https://search.clinicalgenome.org/kb/gene-validity/download" -O clingen_gene_disease_validity.csv
    //   python3 scripts/build_gene_moi.py --clingen_gene clingen_gene_disease_validity.csv --output gene_moi.tsv.gz
    clingen_hi_tsv = "${params.ref_dir}/tertiary/clingen/ClinGen_gene_curation_list_GRCh38.tsv"
    gene_moi_tsv   = "${params.ref_dir}/tertiary/clingen/gene_moi.tsv.gz"

    // GPU / Apptainer 選項預設值（profile 可覆蓋）
    apptainer_base_opts = null
    use_gpu_pangolin    = false
    use_gpu_evo2        = false
}

// ── 執行報告 ──────────────────────────────────────────────────

report   { enabled = true; file = "${params.out_dir}/pipeline_info/execution_report.html";   overwrite = true }
timeline { enabled = true; file = "${params.out_dir}/pipeline_info/execution_timeline.html"; overwrite = true }
trace    { enabled = true; file = "${params.out_dir}/pipeline_info/execution_trace.txt";     overwrite = true }