 * =========================================================
 * nextflow_tertiary.config
 * ========================
 * 三級分析 Nextflow 設定檔
 *
 * 使用方式：
 *   nextflow -c nextflow_tertiary.config run main_tertiary.nf -profile local ...
 *   nextflow -c nextflow_tertiary.config run main_tertiary.nf -profile dgm   ...
 */

// ──────────────────────────────────────────────────────────────
// Apptainer（Singularity）全域設定
// ──────────────────────────────────────────────────────────────

apptainer {
    enabled    = true
    autoMounts = true
    // cacheDir 由各 profile 的 params.sif_dir 決定，這裡不重複設定
}

// ──────────────────────────────────────────────────────────────
// 預設參數（各 profile 可覆蓋）
// ──────────────────────────────────────────────────────────────

params {
    // 必填（執行時傳入）
    sample_id   = null
    input_dir   = null
    out_dir     = null

    // 可選
    seq_type    = "WES"       // WES 或 WGS
    hpo         = ""          // HPO terms，逗號分隔，例如 "HP:0001250,HP:0002376"
    run_evo2    = false        // Phase 4：Evo2 non-coding prediction
    run_phasing = false        // Phase 4：WhatsHap phasing

    // 路徑（各 profile 覆蓋）
    sif_dir     = null
    ref_dir     = null
    scripts_dir = null
}

// ──────────────────────────────────────────────────────────────
// Profiles
// ──────────────────────────────────────────────────────────────

profiles {

    // ── 本機開發測試 ──────────────────────────────────────
    local {
        params {
            sif_dir     = "/data/pylin1991/nf-containers"
            ref_dir     = "/scratch/pylin1991/GenomicReference_Cache/hg38/tertiary"
            scripts_dir = "/data/pylin1991/nf-containers/NGStertiary/1_0_0/scripts"
            out_dir     = "/scratch/pylin1991/tertiary_test"
            vep_cache   = "${params.ref_dir}/vep_cache"
            pangolin_db = "${params.ref_dir}/pangolin/gencode.v47.annotation.db"
            pangolin_ref = "/scratch/pylin1991/GenomicReference_Cache/hg38/Homo_sapiens_assembly38.fasta"
            use_gpu_pangolin = true   // 本機 RTX PRO 6000
            use_gpu_esm      = true   // 本機 RTX PRO 6000 跑 ESM1b
            use_gpu_evo2     = true   // 本機 RTX PRO 6000 跑 Evo2
        }

        apptainer {
            // /scratch 和 /data 掛載，GPU process 額外加 --nv（見下方 process 設定）
            runOptions = "--bind /scratch,/data"
        }

        process {
            withLabel: process_low {
                cpus   = 2
                memory = 8.GB
            }
            withLabel: process_medium {
                cpus   = 8
                memory = 32.GB
            }
            withLabel: process_high {
                cpus   = 16
                memory = 64.GB
            }
            withLabel: process_gpu {
                // --nv：讓 Apptainer 把主機的 CUDA driver bind 進容器
                // 本機 Blackwell RTX PRO 6000（sm_120）需要這個才能用 GPU
                containerOptions = "--nv"
                maxForks = 1
            }
        }
    }
    // ── DGM Server 臨床部署 ───────────────────────────────
    dgm {
        params {
            sif_dir      = "/home/pipeline/nextflow_containers"
            ref_dir      = "/home/pipeline/reference/hg38/tertiary"
            scripts_dir  = "/home/pipeline/tertiary_code/scripts"
            out_dir      = "/home/pipeline/tertiary_output"
            vep_cache    = "${params.ref_dir}/vep_cache"
            pangolin_db  = "${params.ref_dir}/pangolin/gencode.v47.annotation.db"
            pangolin_ref = "/home/pipeline/reference/hg38/Homo_sapiens_assembly38.fasta"
            use_gpu_pangolin = true   // DGM RTX 2000 Ada
            use_gpu_esm      = true
            use_gpu_evo2     = false  // Evo2 不在 DGM 跑，由本機處理
        }
 
        apptainer {
            runOptions = "--bind /home"
        }
 
        process {
            withLabel: process_low {
                cpus   = 2
                memory = 8.GB
            }
            withLabel: process_medium {
                cpus   = 8
                memory = 32.GB
            }
            withLabel: process_high {
                cpus   = 32
                memory = 64.GB
            }
            withLabel: process_gpu {
                containerOptions = "--nv"
                maxForks = 1
            }
        }
    }
}
 
// ──────────────────────────────────────────────────────────────
// 執行紀錄設定
// ──────────────────────────────────────────────────────────────
 
report {
    enabled   = true
    file      = "${params.out_dir}/pipeline_info/execution_report.html"
    overwrite = true
}
 
timeline {
    enabled   = true
    file      = "${params.out_dir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
 
trace {
    enabled   = true
    file      = "${params.out_dir}/pipeline_info/execution_trace.txt"
    overwrite = true
}
 